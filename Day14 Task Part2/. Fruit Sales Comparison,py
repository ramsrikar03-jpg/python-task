import pandas as pd
S1 = pd.Series([10, 20, 30], index=["apple", "banana", "cherry"])
S2 = pd.Series([5, 15, 25], index=["apple", "banana", "cherry"])
total_series = S1 + S2
print("Combined Sales (S1 + S2):")
print(total_series)
total_sales = total_series.sum()
print("\nTotal Sales of all fruits:", total_sales)